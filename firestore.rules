rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'admin' or 'member')
    //   - totalSavings: number (required)
    //   - outstandingLoan: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - type: string (required, 'deposit', 'loan_repayment', 'loan_disbursement', 'other')
    //   - date: timestamp (required)
    //   - description: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: loans
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - principal: number (required)
    //   - interestRate: number (required)
    //   - remainingBalance: number (required)
    //   - status: string (required, 'active', 'paid')
    //   - createdAt: timestamp (required)
    //
    // Collection: society_stats
    // Document ID: 'main'
    // Fields:
    //   - totalBalance: number (required)
    //   - notice: string (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "kuppiya719@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data, isCreate) {
      let allowedFields = ['uid', 'email', 'displayName', 'role', 'totalSavings', 'outstandingLoan', 'createdAt'];
      let requiredFields = ['uid', 'email', 'role', 'totalSavings', 'outstandingLoan'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             data.role in ['admin', 'member'] &&
             data.totalSavings is number && data.totalSavings >= 0 &&
             data.outstandingLoan is number && data.outstandingLoan >= 0 &&
             (!isCreate || data.createdAt is timestamp);
    }

    function isValidTransaction(data, isCreate) {
      let allowedFields = ['userId', 'amount', 'type', 'date', 'description', 'createdAt'];
      let requiredFields = ['userId', 'amount', 'type', 'date', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'loan_repayment', 'loan_disbursement', 'other'] &&
             data.date is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() < 500)) &&
             (!isCreate || data.createdAt is timestamp);
    }

    function isValidLoan(data, isCreate) {
      let allowedFields = ['userId', 'principal', 'interestRate', 'remainingBalance', 'status', 'createdAt'];
      let requiredFields = ['userId', 'principal', 'interestRate', 'remainingBalance', 'status', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.principal is number && data.principal > 0 &&
             data.interestRate is number && data.interestRate >= 0 &&
             data.remainingBalance is number && data.remainingBalance >= 0 &&
             data.status in ['active', 'paid'] &&
             (!isCreate || data.createdAt is timestamp);
    }

    function isValidSocietyStats(data) {
      let allowedFields = ['totalBalance', 'notice', 'updatedAt'];
      let requiredFields = ['totalBalance'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.totalBalance is number && data.totalBalance >= 0 &&
             (!('notice' in data) || (data.notice is string && data.notice.size() < 1000)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow users to create their own profile initially as 'member' with 0 balances, OR admin can create
      allow create: if isAuthenticated() && isValidUser(request.resource.data, true) && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == 'member' && request.resource.data.totalSavings == 0 && request.resource.data.outstandingLoan == 0 && uidUnchanged())
      );
      
      // Only admins can update user balances/roles
      allow update: if isAdmin() && isValidUser(request.resource.data, false) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin() && isValidTransaction(request.resource.data, true);
      allow update: if isAdmin() && isValidTransaction(request.resource.data, false) && areImmutableFieldsUnchanged(['createdAt', 'userId']);
    }

    match /loans/{loanId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin() && isValidLoan(request.resource.data, true);
      allow update: if isAdmin() && isValidLoan(request.resource.data, false) && areImmutableFieldsUnchanged(['createdAt', 'userId']);
    }

    match /society_stats/{statId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidSocietyStats(request.resource.data);
      allow update: if isAdmin() && isValidSocietyStats(request.resource.data);
    }
  }
}
